      ],
      "configBackup": {}
    },
    {
      "name": "omp",
      "command": "omp",
      "protocol": "acp",
      "args": [
        "acp"
      ],
      "configBackup": {
        "fileSources": [
          "~/.omp/agent/.env",
          "~/.omp/.env",
          "~/.omp/agent/config.yml",
          "~/.omp/agent/models.yml",
          "~/.omp/agent/mcp.json",
